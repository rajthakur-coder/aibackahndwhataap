
APP_NAME="AI WhatsApp Automation"
APP_URL=http://localhost:8000
PUBLIC_WEBHOOK_BASE_URL=https://your-api.example.com
PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]
DATABASE_URI=sqlite:///./app.db

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o
ROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_SECONDS=20
FIRECRAWL_API_KEY=your_firecrawl_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key

EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_for_embeddings
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

ECOMMERCE_AUTO_SYNC_CHECKOUTS_ENABLED=false
ECOMMERCE_AUTO_SYNC_INTERVAL_SECONDS=300
ECOMMERCE_AUTO_SYNC_LIMIT=50
ECOMMERCE_AUTO_SYNC_PRODUCTS_ENABLED=true
ECOMMERCE_AUTO_SYNC_PRODUCT_LIMIT=100
SHOPIFY_WEBHOOK_AUTOMATION_ENABLED=false
SHOPIFY_WEBHOOK_SECRET=
INIT_DB_ON_STARTUP=true
RLS_RUNTIME_ROLE=ai_agent_runtime
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
GMAIL_ID=
GMAIL_APP_PASSWORD=
ALIGNAUTH_APP_URL=http://localhost:3001
ARQ_QUEUE_NAME=alignlabs:jobs
ARQ_DEFAULT_TIMEOUT=900
MAX_CONCURRENT_JOBS=5
JOB_MAX_ATTEMPTS=3
SHOPIFY_PRODUCT_CACHE_TTL_SECONDS=3600
SHOPIFY_QUERY_CACHE_TTL_SECONDS=3600
SHOPIFY_ORDER_CACHE_TTL_SECONDS=60
AUTOMATION_PROCESSOR_ENABLED=true
AUTOMATION_PROCESSOR_INTERVAL_SECONDS=60
AUTOMATION_PROCESSOR_LIMIT=50
ABANDONED_CART_DELAY_SECONDS=120

ACCESS_TOKEN=your_whatsapp_access_token
PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_CATALOG_ID=your_whatsapp_commerce_catalog_id
VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_REGISTER_PIN=
WHATSAPP_DATA_LOCALIZATION_REGION=IN

META_APP_ID=your_meta_app_id
